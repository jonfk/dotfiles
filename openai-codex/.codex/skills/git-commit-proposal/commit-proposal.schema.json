{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "stage_paths",
    "commit",
    "alternatives"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "split_required",
        "nothing_to_commit"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "stage_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "commit": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "subject",
            "body_paragraphs"
          ],
          "properties": {
            "subject": {
              "type": "string",
              "minLength": 1
            },
            "body_paragraphs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "summary",
          "commit_subject",
          "stage_paths"
        ],
        "properties": {
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "commit_subject": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "null"
              }
            ]
          },
          "stage_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
